# Copy this file to .env and fill in YOUR values
# ⚠️ NEVER commit .env to git — it contains secrets!

# Your Discord Application's CLIENT ID (from Discord Developer Portal)
DISCORD_CLIENT_ID=1466430209019351050

# Your Discord Application's CLIENT SECRET (from Discord Developer Portal > OAuth2)
DISCORD_CLIENT_SECRET=g7kjCatqyXZlDM95tCDYOtYzgOj3Yx3-

# The redirect URI you registered in Discord Developer Portal
# For local dev: http://localhost:3000/auth/callback
# For production: https://yourdomain.com/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# Random secret string for encrypting sessions (make it long and random)
SESSION_SECRET=change-this-to-a-very-long-random-string-please

# Port to run the server on
PORT=3000
